const supabaseUrl = import.meta.env.VITE_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.VITE_SUPABASE_ANON_KEY;

if (!supabaseUrl) console.error('[ResumeForge] Missing VITE_SUPABASE_URL — copy .env.example → .env');
if (!supabaseAnonKey) console.error('[ResumeForge] Missing VITE_SUPABASE_ANON_KEY — copy .env.example → .env');